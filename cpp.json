{
	// ====================================================================== //
	//    If                                                                  //
	// ====================================================================== //

	"if": {
		"prefix": "if",
		"body": [
			"if (${1:condition})",
			"{",
			"\t${2}",
			"}"
		]
	},

	"ifel": {
		"prefix": "ifel",
		"body": [
			"if (${1:condition})",
			"{",
			"\t${2}",
			"}",
			"else",
			"{",
			"\t${3}",
			"}"
		]
	},

	"ifelif": {
		"prefix": "ifelif",
		"body": [
			"if (${1:condition})",
			"{",
			"\t${3}",
			"}",
			"else if (${2:condition})",
			"{",
			"\t${4}",
			"}",
			"else",
			"{",
			"\t${5}",
			"}"
		]
	},

	"else": {
		"prefix": "else",
		"body": [
			"else",
			"{",
			"\t${1}",
			"}"
		]
	},

	"elif": {
		"prefix": "elif",
		"body": [
			"else if (${1:condition})",
			"{",
			"\t${2}",
			"}"
		]
	},

	// ====================================================================== //
	//    Switch Case                                                         //
	// ====================================================================== //

	"switch": {
		"prefix": "switch",
		"body": [
			"switch (${1:condition})",
			"{",
			"\t${2}",
			"\tdefault: break;",
			"}"
		]
	},

	"case": {
		"prefix": "case",
		"body": [
			"case (${1:condition}):",
			"{",
			"\t${2}",
			"\tbreak;",
			"}"
		]
	},

	// ====================================================================== //
	//    Do While Loop                                                       //
	// ====================================================================== //

	"do": {
		"prefix": "do",
		"body": [
			"do",
			"{",
			"\t${2}",
			"} while (${1:condition})"
		]
	},

	// ====================================================================== //
	//    While Loop                                                          //
	// ====================================================================== //

	"while": {
		"prefix": "while",
		"body": [
			"while (${1:condition})",
			"{",
			"\t${2}",
			"} "
		]
	},

	// ====================================================================== //
	//    For Loop                                                            //
	// ====================================================================== //

	"for": {
		"prefix": "for",
		"body": [
			"for (${1:init}; ${2:condition}; ${3:mod})",
			"{",
			"\t${4}",
			"}"
		]
	},

	"foreach": {
		"prefix": "foreach",
		"body": [
			"for (auto &${1:item} : ${2:container})",
			"{",
			"\t${3}",
			"}"
		]
	},

	// ====================================================================== //
	//    C++ Stuff                                                           //
	// ====================================================================== //

	"class": {
		"prefix": "class",
		"body": [
			"class\t${1:Name}",
			"{",
			"\tpublic:",
			"",
			"\t${2}",
			"",
			"\tprivate:",
			"",
			"\t${3}",
			"};"
		]
	},

	"struct": {
		"prefix": "struct",
		"body": [
			"struct\t${1:Name}",
			"{",
			"\t${2}",
			"};"
		]
	},

	"ns": {
		"prefix": "ns",
		"body": [
			"namespace\t${1:name}",
			"{",
			"\t${2}",
			"}"
		]
	},

	"enum": {
		"prefix": "enum",
		"body": [
			"enum\t${1:Name}",
			"{",
			"\t${2}",
			"};"
		]
	},

	// ====================================================================== //
	//    Miscellaneous                                                       //
	// ====================================================================== //

	"cout": {
		"prefix": "cout",
		"body": [
			"std::cout << \"${1}\\n\";"
		]
	},

	"coutln": {
		"prefix": "coutln",
		"body": [
			"std::cout << \"${1}\" << std::endl;"
		]
	},

	"putain": {
		"prefix": "putain",
		"body": [
			"std::cout << \"${1:var} = \" << ${1:var} << std::endl;"
		]
	},
}
